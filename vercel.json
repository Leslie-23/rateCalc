{
    "version": 2,
    "builds": [
        { "src": "api/rates.js", "use": "@vercel/node" },
        { "src": "index.html", "use": "@vercel/static" },
        { "src": "index.css", "use": "@vercel/static" },
        { "src": "index.js", "use": "@vercel/static" },
        { "src": "config.js", "use": "@vercel/static" },
        { "src": "manifest.json", "use": "@vercel/static" },
        { "src": "sw.js", "use": "@vercel/static" },
        { "src": "icons/**", "use": "@vercel/static" }
    ],
    "routes": [
        { "src": "/api/rates", "dest": "/api/rates.js" },
        { "src": "/", "dest": "/index.html" },
        { "src": "/(.*)", "dest": "/$1" }
    ]
}
